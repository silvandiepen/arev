{
  "name": "@arevs/maps",
  "version": "0.1.21",
  "description": "Map datasets and SVG helpers for the @arevs data packages",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/maps/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/maps/src/index.d.ts"
    },
    "./country-maps": {
      "import": "./dist/data/countryMaps.js",
      "require": "./dist/data/countryMaps.cjs",
      "types": "./dist/types/maps/src/data/countryMaps.d.ts"
    },
    "./world-map": {
      "import": "./dist/data/worldMap.js",
      "require": "./dist/data/worldMap.cjs",
      "types": "./dist/types/maps/src/data/worldMap.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/silvandiepen/arev",
    "directory": "packages/maps"
  },
  "scripts": {
    "build": "vite build --config vite.config.ts"
  }
}
