{
  "name": "@arevs/workspace",
  "version": "0.1.21",
  "description": "Workspace for the @arevs data packages",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/utils",
    "packages/geo",
    "packages/flags",
    "packages/places",
    "packages/maps",
    "packages/astronomy",
    "packages/space",
    "packages/data"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @arevs/data",
    "dev:example": "npm run dev --prefix apps/example",
    "api:dev": "wrangler dev --config apps/api/wrangler.jsonc",
    "api:deploy": "wrangler deploy --config apps/api/wrangler.jsonc",
    "flags:sync": "node scripts/sync-flag-svgs.mjs",
    "flags:build": "npm run flags:sync && node scripts/build-flag-assets.mjs",
    "docs:clean": "node -e \"require('fs').rmSync('apps/docs/public', { recursive: true, force: true })\"",
    "docs:dev": "npm run docs:clean && cd apps/docs && ../../node_modules/.bin/girk",
    "docs:build": "npm run docs:clean && cd apps/docs && ../../node_modules/.bin/girk",
    "docs:deploy": "npm run docs:clean && cd apps/docs && ../../node_modules/.bin/girk && ../../node_modules/.bin/wrangler pages deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "workspace:sync-versions": "node scripts/sync-workspace-versions.mjs",
    "prepublishOnly": "npm run workspace:sync-versions && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "countries",
    "world-data",
    "phone-codes",
    "flags",
    "cities",
    "states",
    "provinces",
    "data",
    "iso-3166"
  ],
  "author": "Sil van Diepen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/arev.git"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.0.0",
    "flag-icons": "^7.5.0",
    "girky": "^1.11.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0",
    "wrangler": "^4.76.0"
  }
}
