{
  "name": "arev",
  "version": "0.1.12",
  "description": "A comprehensive collection of reusable world data: countries, phone codes, flags, cities, states, provinces and more",
  "type": "module",
  "main": "./dist/arev.cjs",
  "module": "./dist/arev.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/arev.js",
      "require": "./dist/arev.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist/types",
    "dev": "vite build --watch",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "countries",
    "world-data",
    "phone-codes",
    "flags",
    "cities",
    "states",
    "provinces",
    "data",
    "iso-3166"
  ],
  "author": "Sil van Diepen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/arev.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0"
  }
}
